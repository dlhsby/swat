/// Metadata for archived (detached + compressed) monthly partitions
/// (specs/12-scalability-archiving.md §3, Phase 2 Epic 2.5). One row per archived
/// partition; `checksum` guards a later re-attach. `createdById` is a plain scalar
/// (no relation) — see the rollup-tables note above.
model ArchiveCatalog {
  id           String    @id @default(uuid(7)) @db.Uuid
  tableName    String    @map("table_name") @db.VarChar(64)
  period       String    @db.VarChar(7) // YYYY-MM
  archiveType  String    @map("archive_type") @db.VarChar(32)
  location     String    @db.VarChar(512)
  rowCount     BigInt    @default(0) @map("row_count")
  sizeBytes    BigInt?   @map("size_bytes")
  checksum     String?   @db.VarChar(128)
  detachedAt   DateTime  @map("detached_at") @db.Timestamptz(6)
  reattachedAt DateTime? @map("reattached_at") @db.Timestamptz(6)
  notes        String?   @db.VarChar(512)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById  String?   @map("created_by_id") @db.Uuid

  @@unique([tableName, period], map: "archive_catalog_table_period_key")
  @@index([period], map: "archive_catalog_period_idx")
  @@map("archive_catalog")
}

