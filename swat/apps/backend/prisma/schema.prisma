// SWAT — PostgreSQL schema (Prisma).
// Source of truth: specs/03-data-model.md. Names follow specs/01-glossary.md.
//
// CONVENTIONS (specs/README.md §Conventions):
//   • DB tables & columns are snake_case via `@@map`/`@map`; Prisma model names
//     stay PascalCase and field names camelCase.
//   • Primary keys are UUID v7 (`String @id @db.Uuid @default(uuid(7))`) on every
//     table — time-ordered for tight index locality on the high-volume
//     partitioned tables. `legacyId` keeps the legacy numeric source PK as the
//     migration bridge (mapped to new UUIDs during the legacy data load).
//
// NOTE on photos: the legacy scalar `photo String?` fields and `dokumentasi*`
// tables are replaced by the polymorphic `Photo` model (ownerType/ownerId).
// Because the pattern is polymorphic, there is intentionally NO Prisma relation
// field back onto User/Vehicle/Driver/Site (a polymorphic owner cannot be a
// typed FK). Photo↔owner integrity is enforced in the API validation layer
// (see specs/03-data-model.md §6).
//
// NOTE on partitioning: Trip/Haul/HaulAssignment (by operationDate) and
// TpaInboundLog (by date) are converted to native RANGE partitioning by a
// raw-SQL migration AFTER the Prisma-generated init migration. Prisma manages
// the logical schema here; the partition migration owns the physical layout.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Enums
// ===========================================================================
enum SiteType {
  POOL
  SPBU
  TPS
  TPA
}

enum RouteCategory {
  DEPART_POOL
  REFUEL
  PICKUP
  DISPOSAL
  RETURN_POOL
}

enum TripStatus {
  IN_PROGRESS
  DONE
  VERIFIED
}

enum DayStatus {
  IN_PROGRESS
  DONE
}

enum DisposalPermitStatus {
  ACTIVE
  INACTIVE
}

enum VehicleStatus {
  GOOD
  MINOR_DAMAGE
  MAJOR_DAMAGE
  LOST
}

enum EmploymentStatus {
  SATGAS
  PNS
  HONORER
}

enum MaintenanceStatus {
  PENDING_APPROVAL
  APPROVED
}

enum MaintenanceType {
  SERVICE
  REPAIR
}

enum InspectionResult {
  PASS
  ATTENTION
  FAIL
}

enum InspectionItemStatus {
  OK
  ATTENTION
  FAIL
}

enum AuthAction {
  LOGIN
  LOGOUT
  FAILED_LOGIN
  PASSWORD_CHANGE
  ACCOUNT_LOCK
  FORCE_RESET
  PERMISSION_DENIED
}

// Which kind of principal authenticated an integration API call (Phase 4
// weighbridge): an interactive operator (OAuth2 bearer) or a machine credential
// (ServiceAccount API key). Recorded on every `ApiAuditLog` row.
enum ApiPrincipalType {
  USER
  SERVICE_ACCOUNT
}

// ===========================================================================
// Auth
// ===========================================================================
model User {
  id                 String    @id @default(uuid(7)) @db.Uuid
  legacyId           Int?      @unique @map("legacy_id")
  roleId             String    @map("role_id") @db.Uuid
  role               Role      @relation(fields: [roleId], references: [id])
  name               String    @db.VarChar(100)
  username           String    @unique @db.VarChar(100)
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  mustChangePassword Boolean   @default(true) @map("must_change_password")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)

  tripsRecordedBy             Trip[]              @relation("TripRecordedBy")
  tripsCreatedBy              Trip[]              @relation("TripCreatedBy")
  tripsUpdatedBy              Trip[]              @relation("TripUpdatedBy")
  tripsVerifiedBy             Trip[]              @relation("TripVerifiedBy")
  haulAssignmentsCreatedBy    HaulAssignment[]    @relation("HaulAssignmentCreatedBy")
  haulAssignmentsUpdatedBy    HaulAssignment[]    @relation("HaulAssignmentUpdatedBy")
  disposalPermitsCreatedBy    DisposalPermit[]    @relation("DisposalPermitCreatedBy")
  disposalPermitsUpdatedBy    DisposalPermit[]    @relation("DisposalPermitUpdatedBy")
  leviesCreatedBy             Levy[]              @relation("LevyCreatedBy")
  leviesUpdatedBy             Levy[]              @relation("LevyUpdatedBy")
  maintenanceRecordsCreatedBy MaintenanceRecord[] @relation("MaintenanceRecordCreatedBy")
  maintenanceRecordsUpdatedBy MaintenanceRecord[] @relation("MaintenanceRecordUpdatedBy")
  inspectionsInspector        VehicleInspection[] @relation("VehicleInspectionInspector")
  inspectionsCreatedBy        VehicleInspection[] @relation("VehicleInspectionCreatedBy")
  reportJobs                  ReportJob[]

  createdById String? @map("created_by_id") @db.Uuid
  updatedById String? @map("updated_by_id") @db.Uuid
  deletedById String? @map("deleted_by_id") @db.Uuid

  @@map("user")
}

model Role {
  id          String           @id @default(uuid(7)) @db.Uuid
  legacyId    Int?             @unique @map("legacy_id")
  name        String           @unique @db.VarChar(100)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  users           User[]
  permissions     RolePermission[]
  serviceAccounts ServiceAccount[]

  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid

  @@map("role")
}

model Permission {
  id          String           @id @default(uuid(7)) @db.Uuid
  key         String           @unique @db.VarChar(64)
  description String           @db.VarChar(255)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  roles       RolePermission[]

  @@map("permission")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permission")
}

model AuthAuditLog {
  id        String     @id @default(uuid(7)) @db.Uuid
  userId    String?    @map("user_id") @db.Uuid
  username  String     @db.VarChar(100)
  action    AuthAction
  ip        String     @db.VarChar(45)
  userAgent String     @map("user_agent") @db.VarChar(512)
  timestamp DateTime   @db.Timestamptz(6)
  details   String?    @db.VarChar(512)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([timestamp])
  @@index([action])
  @@map("auth_audit_log")
}

// Generic audit trail for sensitive, non-auth mutations (user/role CRUD, trip
// verification, fuel over-approval, maintenance approval) — the `AuthAuditLog`
// above stays scoped to authentication events. Append-only; writes never block
// the request (a failed audit is logged, not raised). See specs/10-nonfunctional §1.
model AuditLog {
  id         String   @id @default(uuid(7)) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  actorName  String   @map("actor_name") @db.VarChar(100)
  action     String   @db.VarChar(64)
  entityType String   @map("entity_type") @db.VarChar(48)
  entityId   String   @map("entity_id") @db.VarChar(64)
  details    String?  @db.VarChar(512)
  timestamp  DateTime @default(now()) @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@map("audit_log")
}

// Machine credential for the integration APIs (Phase 4 weighbridge). Used for
// UNATTENDED paths — offline-queue sync, Excel bulk upload, the TPA-side kitir
// push — where no human is logged in. The interactive weighbridge flow uses a
// per-operator OAuth2 bearer instead (see specs/09-modules/integration-weighbridge.md
// §4). The full key is shown ONCE on creation; only its bcrypt/argon2 hash is
// stored. `apiKeyPrefix` (first 8 chars) lets admins identify a key in lists.
// `roleId` reuses the RBAC role machinery so permission checks are identical to
// users. `allowedIPs` (empty = any) gates by source IP.
model ServiceAccount {
  id              String    @id @default(uuid(7)) @db.Uuid
  legacyId        Int?      @unique @map("legacy_id")
  name            String    @db.VarChar(100)
  apiKeyHash      String    @map("api_key_hash") @db.VarChar(255)
  apiKeyPrefix    String    @map("api_key_prefix") @db.VarChar(16)
  roleId          String    @map("role_id") @db.Uuid
  role            Role      @relation(fields: [roleId], references: [id])
  active          Boolean   @default(true)
  rateLimitPerMin Int       @default(500) @map("rate_limit_per_min")
  allowedIPs      String[]  @map("allowed_ips")
  lastUsedAt      DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)

  createdById String? @map("created_by_id") @db.Uuid
  updatedById String? @map("updated_by_id") @db.Uuid

  @@index([active])
  @@index([apiKeyPrefix])
  @@map("service_account")
}

// Append-only audit trail for integration API calls (Phase 4 weighbridge). One
// row per call: who (principalType+id+name), what (method+endpoint), outcome
// (statusCode), and short request/response summaries — NEVER keys, passwords, or
// full bodies. Principal-agnostic (no FK) so it can reference either a User or a
// ServiceAccount. See specs/09-modules/integration-weighbridge.md §9.3.
model ApiAuditLog {
  id              String           @id @default(uuid(7)) @db.Uuid
  principalType   ApiPrincipalType @map("principal_type")
  principalId     String?          @map("principal_id") @db.Uuid
  principalName   String           @map("principal_name") @db.VarChar(100)
  method          String           @db.VarChar(10)
  endpoint        String           @db.VarChar(256)
  statusCode      Int              @map("status_code")
  requestSummary  String?          @map("request_summary") @db.VarChar(512)
  responseSummary String?          @map("response_summary") @db.VarChar(512)
  ipAddress       String           @map("ip_address") @db.VarChar(45)
  userAgent       String           @map("user_agent") @db.VarChar(512)
  timestamp       DateTime         @default(now()) @db.Timestamptz(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([timestamp])
  @@index([principalId])
  @@index([endpoint])
  @@index([statusCode])
  @@map("api_audit_log")
}

// ===========================================================================
// Fleet
// ===========================================================================
model VehicleType {
  id        String         @id @default(uuid(7)) @db.Uuid
  legacyId  Int?           @unique @map("legacy_id")
  name      String         @db.VarChar(100)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  models    VehicleModel[]

  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid

  @@map("vehicle_type")
}

model FuelCategory {
  id        String   @id @default(uuid(7)) @db.Uuid
  legacyId  Int?     @unique @map("legacy_id")
  name      String   @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  fuels     Fuel[]

  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid

  @@map("fuel_category")
}

model Fuel {
  id             String         @id @default(uuid(7)) @db.Uuid
  legacyId       Int?           @unique @map("legacy_id")
  fuelCategoryId String         @map("fuel_category_id") @db.Uuid
  fuelCategory   FuelCategory   @relation(fields: [fuelCategoryId], references: [id])
  name           String         @db.VarChar(100)
  pricePerLiter  Int            @default(0) @map("price_per_liter")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  models         VehicleModel[]

  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid

  @@map("fuel")
}

model VehicleModel {
  id               String      @id @default(uuid(7)) @db.Uuid
  legacyId         Int?        @unique @map("legacy_id")
  vehicleTypeId    String      @map("vehicle_type_id") @db.Uuid
  vehicleType      VehicleType @relation(fields: [vehicleTypeId], references: [id])
  fuelId           String      @map("fuel_id") @db.Uuid
  fuel             Fuel        @relation(fields: [fuelId], references: [id])
  brand            String      @db.VarChar(100)
  fuelTankCapacity Int         @map("fuel_tank_capacity")
  normalFuelRatio  Int         @default(1) @map("normal_fuel_ratio")
  normalTareWeight Int         @map("normal_tare_weight")
  maxNetLoad       Int?        @default(0) @map("max_net_load")
  maxNetVolume     Int?        @default(0) @map("max_net_volume")
  wheelCount       Int         @map("wheel_count")
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  vehicles         Vehicle[]

  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid

  @@map("vehicle_model")
}

model Vehicle {
  id                 String               @id @default(uuid(7)) @db.Uuid
  legacyId           Int?                 @unique @map("legacy_id")
  poolSiteId         String               @map("pool_site_id") @db.Uuid
  poolSite           Site                 @relation("VehiclePool", fields: [poolSiteId], references: [id])
  modelId            String               @map("model_id") @db.Uuid
  model              VehicleModel         @relation(fields: [modelId], references: [id])
  status             VehicleStatus        @default(GOOD)
  // VarChar(20) (not 10) so the legacy loader can disambiguate the ~1.5% of
  // historical rows with a blank/placeholder/duplicate plate by suffixing the
  // legacy id (e.g. `B9552EQ#1048`); `needsPlateReview` flags those for ops.
  plateNumber        String               @unique @map("plate_number") @db.VarChar(20)
  needsPlateReview   Boolean              @default(false) @map("needs_plate_review")
  chassisNumber      String               @map("chassis_number") @db.VarChar(100)
  engineNumber       String               @map("engine_number") @db.VarChar(100)
  manufactureYear    Int?                 @map("manufacture_year")
  currentFuelRatio   Int                  @default(1) @map("current_fuel_ratio")
  currentTareWeight  Int                  @map("current_tare_weight")
  currentOdometer    Int                  @map("current_odometer")
  registrationExpiry DateTime             @map("registration_expiry") @db.Date
  taxExpiry          DateTime             @map("tax_expiry") @db.Date
  notes              String?              @db.VarChar(512)
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?            @map("deleted_at") @db.Timestamptz(6)
  hauls              Haul[]
  scheduleTemplates      ScheduleTemplate[]
  disposalPermits    DisposalPermit[]
  wasteSources       VehicleWasteSource[]
  maintenance        MaintenanceRecord[]
  inspections        VehicleInspection[]

  createdById String? @map("created_by_id") @db.Uuid
  updatedById String? @map("updated_by_id") @db.Uuid
  deletedById String? @map("deleted_by_id") @db.Uuid

  @@index([poolSiteId])
  @@index([modelId])
  @@map("vehicle")
}

// ===========================================================================
// Personnel
// ===========================================================================
model LicenseClass {
  id        String          @id @default(uuid(7)) @db.Uuid
  legacyId  Int?            @unique @map("legacy_id")
  name      String          @db.VarChar(10)
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  licenses  DriverLicense[]

  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid

  @@map("license_class")
}

model Driver {
  id               String           @id @default(uuid(7)) @db.Uuid
  legacyId         Int?             @unique @map("legacy_id")
  poolSiteId       String           @map("pool_site_id") @db.Uuid
  poolSite         Site             @relation("DriverPool", fields: [poolSiteId], references: [id])
  employmentStatus EmploymentStatus @map("employment_status")
  name             String           @db.VarChar(100)
  idCardNumber     String           @map("id_card_number") @db.VarChar(16)
  originAddress    String           @map("origin_address") @db.VarChar(256)
  currentAddress   String           @map("current_address") @db.VarChar(256)
  birthDate        DateTime         @map("birth_date") @db.Date
  contact          String           @db.VarChar(100)
  safetyTraining   String?          @default("BELUM") @map("safety_training") @db.VarChar(100)
  notes            String?          @db.VarChar(256)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?        @map("deleted_at") @db.Timestamptz(6)
  licenses         DriverLicense[]
  scheduleTemplates    ScheduleTemplate[]
  haulAssignments  HaulAssignment[]

  createdById String? @map("created_by_id") @db.Uuid
  updatedById String? @map("updated_by_id") @db.Uuid
  deletedById String? @map("deleted_by_id") @db.Uuid

  @@index([poolSiteId])
  @@map("driver")
}

model DriverLicense {
  id             String       @id @default(uuid(7)) @db.Uuid
  legacyId       Int?         @unique @map("legacy_id")
  driverId       String       @map("driver_id") @db.Uuid
  driver         Driver       @relation(fields: [driverId], references: [id])
  licenseClassId String       @map("license_class_id") @db.Uuid
  licenseClass   LicenseClass @relation(fields: [licenseClassId], references: [id])
  licenseNumber  String       @map("license_number") @db.VarChar(12)
  expiry         DateTime     @db.Date
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid

  @@map("driver_license")
}

// ===========================================================================
// Geography
// ===========================================================================
model Site {
  id                String           @id @default(uuid(7)) @db.Uuid
  legacyId          Int?             @unique @map("legacy_id")
  type              SiteType
  name              String           @db.VarChar(256)
  address           String           @db.VarChar(512)
  latitude          Decimal?         @db.Decimal(11, 6)
  longitude         Decimal?         @db.Decimal(11, 6)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?        @map("deleted_at") @db.Timestamptz(6)
  originRoutes      Route[]          @relation("RouteOrigin")
  destinationRoutes Route[]          @relation("RouteDestination")
  originTripTemplates      TripTemplate[] @relation("TripTemplateOrigin")
  destinationTripTemplates TripTemplate[] @relation("TripTemplateDestination")
  pooledVehicles    Vehicle[]        @relation("VehiclePool")
  pooledDrivers     Driver[]         @relation("DriverPool")
  disposalPermits   DisposalPermit[]

  createdById String? @map("created_by_id") @db.Uuid
  updatedById String? @map("updated_by_id") @db.Uuid
  deletedById String? @map("deleted_by_id") @db.Uuid

  @@index([type])
  @@map("site")
}

model Route {
  id                String         @id @default(uuid(7)) @db.Uuid
  legacyId          Int?           @unique @map("legacy_id")
  category          RouteCategory
  originSiteId      String         @map("origin_site_id") @db.Uuid
  originSite        Site           @relation("RouteOrigin", fields: [originSiteId], references: [id])
  destinationSiteId String         @map("destination_site_id") @db.Uuid
  destinationSite   Site           @relation("RouteDestination", fields: [destinationSiteId], references: [id])
  distanceKm        Int            @map("distance_km")
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?      @map("deleted_at") @db.Timestamptz(6)
  trips             Trip[]
  tripTemplates     TripTemplate[]

  createdById String? @map("created_by_id") @db.Uuid
  updatedById String? @map("updated_by_id") @db.Uuid
  deletedById String? @map("deleted_by_id") @db.Uuid

  @@unique([originSiteId, destinationSiteId, category])
  @@map("route")
}

// ===========================================================================
// Waste
// ===========================================================================
model WasteSource {
  id        String               @id @default(uuid(7)) @db.Uuid
  legacyId  Int?                 @unique @map("legacy_id")
  code      String               @unique @db.VarChar(5)
  name      String               @db.VarChar(128)
  notes     String?              @db.VarChar(1024)
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  vehicles  VehicleWasteSource[]

  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid

  @@map("waste_source")
}

model VehicleWasteSource {
  id            String      @id @default(uuid(7)) @db.Uuid
  vehicleId     String      @map("vehicle_id") @db.Uuid
  vehicle       Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  wasteSourceId String      @map("waste_source_id") @db.Uuid
  wasteSource   WasteSource @relation(fields: [wasteSourceId], references: [id])
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid

