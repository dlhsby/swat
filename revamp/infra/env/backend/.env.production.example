# SWAT backend — ON-PREM PRODUCTION runtime env (template).
#
# Production is platform-agnostic (the client's own server, docker-compose.prod.yml),
# NOT AWS — so no RDS, no S3 instance role. Storage is self-hosted MinIO; the DB is a
# local/on-prem Postgres. Fill REAL values, then encrypt (the ciphertext is safe to
# commit; the private key stays out-of-band).
#
# Workflow (mirrors staging — see infra/aws/README.md):
#   1. cp infra/env/backend/.env.production.example infra/env/backend/.env.production
#   2. fill in REAL values below (esp. DATABASE_URL — the on-prem Postgres)
#   3. pnpm dlx @dotenvx/dotenvx encrypt -f infra/env/backend/.env.production
#      → rewrites the file as `encrypted:…` ciphertext (safe to commit) and writes
#        DOTENV_PRIVATE_KEY_PRODUCTION to infra/env/backend/.env.keys (GITIGNORED).
#   4. store that private key in the client's secret store / password manager
#      (the on-prem analogue of SSM — there is no AWS here). The runtime decrypts the
#      committed ciphertext at boot; `infra/seed-legacy-from-dump.sh production` decrypts
#      DATABASE_URL from the SAME file to seed the production DB.
#   5. commit the encrypted infra/env/backend/.env.production.
#
# NODE_ENV / BE_PORT / REDIS_URL are set by docker-compose.prod.yml and override anything here.

# --- Database (on-prem Postgres 15) — FILL BEFORE CUTOVER -------------------
# The seed/migration and the runtime both read this. Point at the production Postgres.
DATABASE_URL=postgresql://swat:CHANGE_ME@postgres:5432/swat?schema=public

# --- Auth / sessions --------------------------------------------------------
SESSION_SECRET=CHANGE_ME_min_16_chars_random
JWT_SECRET=CHANGE_ME_min_16_chars_random

# Single-host deploy: web + API behind the same origin (set to the client's domain/IP).
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SAMESITE=lax

# --- CORS (pin to the web origin; credentials are always allowed) -----------
CORS_ORIGIN=https://CHANGE_ME

# --- Object storage: self-hosted MinIO (static keys, path-style) ------------
S3_USE_INSTANCE_ROLE=false
S3_FORCE_PATH_STYLE=true
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=swat-photos
S3_REPORTS_BUCKET=swat-reports

# --- Maps: server-side Google Directions (Phase 7.8) ------------------------
# Snaps a route's auto-default corridor to roads. Optional: leave empty → a route's
# default corridor is a straight line between its sites. Restrict the key by the
# production server's egress IP, Directions API enabled.
GOOGLE_MAPS_SERVER_KEY=

# --- GPS tracking — GPS.id integration (Phase 7) ----------------------------
# Inbound webhook (PRIMARY push path). REQUIRED in production (boot fails without it);
# GPS.id POSTs to /integrations/gps/webhook/<token>. Generate a long random secret.
GPS_WEBHOOK_TOKEN=CHANGE_ME_min_16_chars_random
GPS_WEBHOOK_ALLOWED_IPS=
GPS_INGEST_RATE_LIMIT_PER_MIN=600
GPS_DEVICE_OFFLINE_MINUTES=10

# GPS.id pull API (SECONDARY — nightly backfill + mileage reconcile). All three
# REQUIRED together to enable the nightly job; leave empty to disable it.
# Base URL is the vendor portal backend (NOT api.gps.id); fill USERNAME/PASSWORD at cutover.
GPSID_BASE_URL=https://portal.gps.id/backend/seen/public
GPSID_USERNAME=CHANGE_ME
GPSID_PASSWORD=CHANGE_ME

# --- Archiving (cold storage of partitions >13 months) ----------------------
# Where the monthly archiving cron writes detached-partition dumps (.sql.gz + checksum).
# Mount a durable volume here in docker-compose.prod.yml.
ARCHIVE_DIR=/var/lib/swat/archive
