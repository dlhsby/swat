# ============================================================================
# Production env for the SWAT containerised stack (T-165).
# Copy to `docker-compose.prod.env` (gitignored) and set REAL secrets:
#   cp infra/docker-compose.prod.env.example infra/docker-compose.prod.env
# Consumed via:
#   docker compose -f infra/docker-compose.prod.yml --env-file infra/docker-compose.prod.env up -d --build
#
# NEVER commit the filled-in file. Generate strong secrets, e.g.:
#   openssl rand -base64 48
# ============================================================================

# --- Database ----------------------------------------------------------------
POSTGRES_USER=swat
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=swat

# --- Session / auth secrets (each ≥16 chars; long + random) ------------------
# Rotating SESSION_SECRET invalidates all active sessions. Both are required by
# the backend's env validation — boot fails fast if missing.
SESSION_SECRET=CHANGE_ME_64+_char_random_secret
JWT_SECRET=CHANGE_ME_64+_char_random_secret

# --- Object storage (MinIO / S3) ---------------------------------------------
MINIO_ROOT_USER=swat
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_secret
S3_REGION=us-east-1
S3_BUCKET=swat-photos

# --- Public ingress ----------------------------------------------------------
# Host port Nginx listens on (front this with TLS termination in real prod).
PUBLIC_HTTP_PORT=80

# Optional CORS allowlist (comma-separated origins). Leave blank to reflect the
# request origin (safe behind the same-origin Nginx). Set to lock the API down,
# e.g. CORS_ORIGIN=https://swat.dlh.surabaya.go.id
CORS_ORIGIN=
