# ============================================================================
# SWAT environment template.
# Copy to `.env.local` (gitignored) and adjust for your machine.
#   cp .env.example .env.local
# Docker-compose reads infra/docker-compose.env for container defaults; the
# values below must stay consistent with it for local development.
# ============================================================================

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development
# Backend HTTP port. Loaded from this file by @nestjs/config — change it here
# if :3000 collides with another project, then point NEXT_PUBLIC_API_BASE_URL
# (and CORS_ORIGIN, if you pin it) at the new port.
BE_PORT=3000
LOG_LEVEL=debug

# CORS allowlist for the web client (comma-separated origins). Leave unset in
# dev — the backend then reflects the request origin, so any web port works.
# Pin it in production, e.g. CORS_ORIGIN=https://swat.example.go.id
# CORS_ORIGIN=

# --- Database (PostgreSQL) ---------------------------------------------------
# Must match POSTGRES_* in infra/docker-compose.env.
POSTGRES_PASSWORD=swat_dev_password
DATABASE_URL=postgresql://swat:swat_dev_password@localhost:5432/swat?schema=public

# --- Auth / sessions ---------------------------------------------------------
# Generate strong values for any non-local environment.
SESSION_SECRET=dev-session-secret-change-me-please
JWT_SECRET=dev-jwt-secret-change-me-please

# --- Cache (Redis) -----------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO / S3) ---------------------------------------------
# Must match MINIO_ROOT_* in infra/docker-compose.env.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=swat-photos
S3_ACCESS_KEY=swat
S3_SECRET_KEY=swat_dev_secret
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=swat
MINIO_ROOT_PASSWORD=swat_dev_secret

# --- GPS tracking (Phase 7) --------------------------------------------------
# GPS.id pushes positions to POST /integrations/gps/webhook/:token. The vendor
# webhook is unauthenticated, so SWAT secures it with a secret path token
# (constant-time compare) + optional IP allowlist + rate-limit + audit.
# REQUIRED in production; if left empty in dev the webhook rejects every call
# (rather than booting an open, unauthenticated ingress). Min 16 chars.
GPS_WEBHOOK_TOKEN=
# Comma-separated source-IP allowlist for the webhook. Empty → allow any IP and
# rely on the token. Set to GPS.id's egress addresses to lock it down.
GPS_WEBHOOK_ALLOWED_IPS=
# Per-minute webhook rate limit, keyed by source IP (fleet pushes every ~30s).
GPS_INGEST_RATE_LIMIT_PER_MIN=600
# A device with no ping within this many minutes is flagged offline on the map.
GPS_DEVICE_OFFLINE_MINUTES=10
# GPS.id pull API (secondary, nightly batch: backfill + fuel/mileage reconcile).
# Operator provides the real values — leave unset to disable the nightly pull
# (the client then refuses to run rather than issuing an unauthenticated call).
GPSID_BASE_URL=
GPSID_USERNAME=
GPSID_PASSWORD=

# Server-side Google Directions key for snapping a route's auto-default corridor to
# roads. NOT the browser key (that one is referrer-restricted) — use a separate key
# restricted by IP, with the Directions API enabled. Unset → default = straight line.
GOOGLE_MAPS_SERVER_KEY=

# --- Frontend (Next.js) ------------------------------------------------------
# Base URL of the backend (must match BE_PORT above). The api-client appends /api/v1.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
# Google Maps JavaScript API key for the Pengangkutan (hauling) monitoring map.
# Optional: empty → the map shows a "peta belum dikonfigurasi" placeholder and
# everything else works. start.sh exports this file, so this is the single
# source of truth when launching via ./scripts/start.sh.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Web dev/start port. NOTE: this is a *shell* variable, not loaded from this
# file — Next picks the port before it reads .env. Export it (or prefix the
# command) to override the 3001 default, e.g.:
#   WEB_PORT=4001 pnpm --filter @swat/web dev
# WEB_PORT=3001
