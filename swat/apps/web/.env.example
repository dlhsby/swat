# Web app environment (setup.sh creates .env.local from this; the api-client
# appends /api/v1).
#
# You normally DON'T edit this for ports: ./scripts/start.sh exports the root
# .env.local, and an exported env var overrides this file — so root .env.local
# (BE_PORT / NEXT_PUBLIC_API_BASE_URL) stays the single source of truth. This
# value only takes effect when you run the web standalone WITHOUT start.sh
# (e.g. `pnpm --filter @swat/web dev`); set it to match the backend then.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Google Maps JavaScript API key for the Pengangkutan (hauling) monitoring map.
# Optional: when unset, the map renders a "peta belum dikonfigurasi" placeholder
# and every other view keeps working. Get a key from Google Cloud (Maps
# JavaScript API enabled + billing) and restrict it to your web origins.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# The web dev/start port is set via the WEB_PORT *shell* variable (default
# 3001), not from this file — Next reads its port before loading .env. Override
# it on the command line, e.g.:  WEB_PORT=4001 pnpm --filter @swat/web dev
