# SWAT web — AWS staging BUILD env (template).
#
# NEXT_PUBLIC_* are inlined into the Next bundle at BUILD time. The Dockerfile.web
# staging build decrypts this file with the dotenvx private key (passed as a
# BuildKit secret from the GitHub Actions env secret WEB_DOTENV_PRIVATE_KEY).
#
# Workflow:
#   1. cp infra/env/web/.env.staging.example infra/env/web/.env.staging
#   2. fill in REAL values
#   3. pnpm dlx @dotenvx/dotenvx encrypt -f infra/env/web/.env.staging
#      → ciphertext (commit) + infra/env/web/.env.keys (GITIGNORED)
#   4. add the private key (DOTENV_PRIVATE_KEY_STAGING from .env.keys) as the GitHub
#      environment secret WEB_DOTENV_PRIVATE_KEY (staging environment).
#   5. commit the encrypted infra/env/web/.env.staging.

# Split-domain: the browser calls the API on its own subdomain.
NEXT_PUBLIC_API_BASE_URL=https://api.swat.wahyutrip.com

# Optional — only if the maps feature is exercised on staging.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
