{
  "name": "@swat/backend",
  "version": "0.1.0",
  "private": true,
  "description": "SWAT backend API (NestJS + Prisma + PostgreSQL)",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "migrate:discovery": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\"}' ts-node scripts/migration/migrate-discovery.ts",
    "migrate:legacy": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\"}' ts-node scripts/migration/migrate-legacy.ts",
    "migrate:images": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\"}' ts-node scripts/migration/migrate-images.ts",
    "migrate:verify": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\"}' ts-node scripts/migration/verify-migration.ts",
    "migrate:delta-sync": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\"}' ts-node scripts/migration/delta-sync.ts",
    "rollup:backfill": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\"}' ts-node scripts/backfill-rollups.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json --passWithNoTests",
    "prisma": "prisma",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "seed:demo": "prisma db seed",
    "seed:auth": "SEED_AUTH_ONLY=true prisma db seed",
    "seed:legacy": "pnpm run migrate:legacy",
    "seed:staging": "SEED_ENV=staging pnpm run migrate:legacy -- --include-transactions",
    "seed:production": "SEED_ENV=production pnpm run migrate:legacy -- --include-transactions --confirm-production"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.687.0",
    "@aws-sdk/s3-request-presigner": "^3.687.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.6",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.6",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.4.6",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "connect-redis": "^9.0.0",
    "exceljs": "^4.4.0",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "pdfmake": "^0.3.11",
    "redis": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.6",
    "@swat/eslint-config": "workspace:*",
    "@swat/tsconfig": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@types/pdfmake": "^0.3.3",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "mysql2": "^3.22.5",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
