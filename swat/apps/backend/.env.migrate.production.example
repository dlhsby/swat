# Production migration target (the real cutover) — used by
# `pnpm --filter @swat/backend seed:production`. Copy to `.env.migrate.production`
# (gitignored) and fill in real values. The seed:production script sets
# SEED_ENV=production and passes --confirm-production; the migration REFUSES to
# run against a production target without that acknowledgement.
#
# Runs the full master/auth/scheduling/aggregate load PLUS transactional history.
# Do NOT use --force-reset here unless you intend to truncate the target.

# --- Target PostgreSQL (production) -----------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@PROD_HOST:5432/swat?schema=public

# --- Legacy MySQL source (dkp_swat) -----------------------------------------
LEGACY_DB_HOST=legacy-host
LEGACY_DB_PORT=3306
LEGACY_DB_USER=AdminDKP
LEGACY_DB_PASSWORD=
LEGACY_DB_NAME=dkp_swat

# Password set on every migrated legacy user (forced first-login reset).
LEGACY_SEED_PASSWORD=Password123!
