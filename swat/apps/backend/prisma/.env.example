# Prisma CLI reads DATABASE_URL from this file (prisma/.env) automatically.
# Copy to prisma/.env (gitignored) for local migrate/seed/studio commands:
#   cp prisma/.env.example prisma/.env
# Must match DATABASE_URL in the repo-root .env.local.
DATABASE_URL=postgresql://swat:swat_dev_password@localhost:5432/swat?schema=public
