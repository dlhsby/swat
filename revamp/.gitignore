# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
out/
*.tsbuildinfo

# Test / coverage
coverage/
.turbo/

# Env files (never commit secrets)
.env
.env.local
.env.*.local
# Staging/production seeding reads DATABASE_URL from the encrypted infra/env/*/.env.staging
# (decrypted by the dump helper); there is no separate plaintext seed env file. Safety net:
# never commit a stray plaintext .env.staging/.env.production outside infra/env/ (the encrypted
# runtime files there are re-included below).
.env.staging
.env.production
apps/backend/prisma/.env
infra/docker-compose.env

# dotenvx deploy runtime env — the infra/env/** files are ENCRYPTED ciphertext and
# ARE committed (safe); only the dotenvx private keys (.env.keys) must never be.
!infra/env/backend/.env.staging
!infra/env/web/.env.staging
!infra/env/backend/.env.production
.env.keys
infra/env/**/.env.keys

# Prisma generated client
apps/backend/prisma/generated/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# PWA generated artifacts
public/sw.js
public/workbox-*.js
public/service-worker.js
