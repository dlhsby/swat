# Web app environment. Copy to .env.local for local dev.
# Base URL of the NestJS backend (the api-client appends /api/v1). Must match
# the backend PORT — change this if you moved the backend off :3000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# The web dev/start port is set via the WEB_PORT *shell* variable (default
# 3001), not from this file — Next reads its port before loading .env. Override
# it on the command line, e.g.:  WEB_PORT=4001 pnpm --filter @swat/web dev
