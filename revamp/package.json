{
  "name": "swat",
  "version": "0.1.0",
  "private": true,
  "description": "SWAT — fleet & waste-transport operations platform (monorepo root)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "db:generate": "pnpm --filter @swat/backend run prisma:generate",
    "db:migrate": "pnpm --filter @swat/backend run prisma:deploy",
    "db:seed": "pnpm --filter @swat/backend run seed:demo",
    "db:seed:demo": "pnpm --filter @swat/backend run seed:demo",
    "db:seed:auth": "pnpm --filter @swat/backend run seed:auth",
    "db:seed:legacy": "pnpm --filter @swat/backend run seed:legacy",
    "seed:staging": "bash infra/seed-legacy-from-dump.sh staging --with-transactions",
    "seed:staging:master": "bash infra/seed-legacy-from-dump.sh staging",
    "seed:production": "bash infra/seed-legacy-from-dump.sh production --with-transactions --confirm-production",
    "refresh:demo-fixtures": "bash infra/refresh-demo-fixtures.sh",
    "prepare": "husky",
    "postinstall": "pnpm --filter @swat/backend run prisma:generate || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@swat/eslint-config": "workspace:*",
    "@swat/tsconfig": "workspace:*",
    "@types/node": "^24.13.2",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,cjs,mjs,json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "form-data": "^4.0.6",
      "tmp": "^0.2.7",
      "qs": "^6.15.2",
      "postcss": "^8.5.15",
      "webpack": "^5.107.2",
      "js-yaml": "^4.2.0",
      "lodash": "^4.18.1",
      "ajv@>=7.0.0 <8.18.0": "^8.18.0",
      "glob@>=10.2.0 <10.5.0": "^10.5.0",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.2",
      "esbuild@<0.28.1": "^0.28.1",
      "@hono/node-server@<1.19.13": "^1.19.13",
      "uuid@<11.1.1": "^11.1.1"
    }
  }
}
