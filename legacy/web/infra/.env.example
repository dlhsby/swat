# Infra configuration for the SWAT local Docker stack.
#
# Copy this file to `.env` and adjust as needed:
#   cp old_swat/infra/.env.example old_swat/infra/.env
#
# docker compose (and scripts/setup.sh) automatically read `.env` from this folder.
# These values are the DEFAULTS — `.env` overrides them.

# --- Host ports ---
APP_PORT=8080
DB_PORT=3306
ADMINER_PORT=8083

# --- Database (local use only) ---
MYSQL_DATABASE=dkp_swat
MYSQL_USER=AdminDKP
MYSQL_PASSWORD=Dkpmenur31
MYSQL_ROOT_PASSWORD=root
