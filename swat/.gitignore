# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
out/
*.tsbuildinfo

# Test / coverage
coverage/
.turbo/

# Env files (never commit secrets)
.env
.env.local
.env.*.local
# Legacy-migration env: SEED_ENV=<env> loads `.env.migrate.<env>` (seed:staging →
# .env.migrate.staging, seed:production → .env.migrate.production, the dump helper →
# .env.migrate.legacydump). Real files hold DATABASE_URL + LEGACY_DB_* secrets; only
# the *.example templates are committed. Named `.env.migrate.*` so they never collide
# with the deploy-runtime `infra/env/*/.env.staging` below.
.env.migrate.*
!.env.migrate.*.example
# Safety net: no stray plaintext .env.staging/.env.production outside infra/env/.
.env.staging
.env.production
apps/backend/prisma/.env
infra/docker-compose.env

# dotenvx deploy runtime env — the infra/env/** files are ENCRYPTED ciphertext and
# ARE committed (safe); only the dotenvx private keys (.env.keys) must never be.
!infra/env/backend/.env.staging
!infra/env/web/.env.staging
.env.keys
infra/env/**/.env.keys

# Prisma generated client
apps/backend/prisma/generated/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# PWA generated artifacts
public/sw.js
public/workbox-*.js
public/service-worker.js
