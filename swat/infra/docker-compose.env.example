# ============================================================================
# Docker-compose defaults for the SWAT local stack.
# Copy to `docker-compose.env` (gitignored) and adjust for your machine:
#   cp infra/docker-compose.env.example infra/docker-compose.env
# Consumed via: docker compose --env-file infra/docker-compose.env up -d
#
# Keep the credentials below consistent with the repo-root .env.local used by
# the apps. If you change a *_PORT here, update the matching URL in .env.local
# (e.g. POSTGRES_PORT -> DATABASE_URL, REDIS_PORT -> REDIS_URL,
# MINIO_API_PORT -> S3_ENDPOINT).
# ============================================================================

# --- Credentials -------------------------------------------------------------
POSTGRES_USER=swat
POSTGRES_PASSWORD=swat_dev_password
POSTGRES_DB=swat

MINIO_ROOT_USER=swat
MINIO_ROOT_PASSWORD=swat_dev_secret

# --- Host ports (left = host, container side is fixed) -----------------------
# Override any of these if a port is already taken on your machine.
POSTGRES_PORT=5432
ADMINER_PORT=8080
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
NGINX_PORT=8088

# --- Nginx upstream ports (host apps run via `pnpm dev`) ---------------------
# Where nginx looks for the backend / web on the host. Defaults match the app
# defaults (backend BE_PORT=3000, web WEB_PORT=3001). If you remap the backend
# (e.g. BE_PORT=4020 in .env.local to dodge a :3000 collision), set BACKEND_PORT
# to match here so the same-origin proxy (and the Playwright e2e) keep working.
BACKEND_PORT=3000
WEB_PORT=3001
