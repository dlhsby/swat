# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
out/
*.tsbuildinfo

# Test / coverage
coverage/
.turbo/

# Env files (never commit secrets)
.env
.env.local
.env.*.local
# Per-target migration env (seed:staging / seed:production) — real files hold
# DATABASE_URL + LEGACY_DB_* secrets; only the *.example templates are committed.
.env.staging
.env.production
!.env.staging.example
!.env.production.example
apps/backend/prisma/.env
infra/docker-compose.env

# dotenvx deploy runtime env — the infra/env/** files are ENCRYPTED ciphertext and
# ARE committed (safe); only the dotenvx private keys (.env.keys) must never be.
!infra/env/backend/.env.staging
!infra/env/web/.env.staging
.env.keys
infra/env/**/.env.keys

# Prisma generated client
apps/backend/prisma/generated/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# PWA generated artifacts
public/sw.js
public/workbox-*.js
public/service-worker.js
