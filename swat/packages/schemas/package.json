{
  "name": "@swat/schemas",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@swat/eslint-config": "workspace:*",
    "@swat/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  }
}
