# Staging migration target (UAT) — used by `pnpm --filter @swat/backend seed:staging`.
# Copy to `.env.staging` (gitignored) and fill in real values. The seed:staging
# script sets SEED_ENV=staging, which loads THIS file before the migration runs.
#
# Loads the legacy MySQL source + the staging PostgreSQL target, then runs the
# full master/auth/scheduling/aggregate load PLUS the transactional history
# (--include-transactions).

# --- Target PostgreSQL (staging) --------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@STAGING_HOST:5432/swat?schema=public

# --- Legacy MySQL source (dkp_swat) -----------------------------------------
LEGACY_DB_HOST=legacy-host
LEGACY_DB_PORT=3306
LEGACY_DB_USER=AdminDKP
LEGACY_DB_PASSWORD=
LEGACY_DB_NAME=dkp_swat

# Password set on every migrated legacy user (forced first-login reset).
LEGACY_SEED_PASSWORD=Password123!
