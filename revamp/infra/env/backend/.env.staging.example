# SWAT backend — AWS staging RUNTIME env (template).
#
# This is the deploy-time runtime config for the staging backend container — NOT
# the legacy-seed file (that's apps/backend/.env.staging, used by seed:staging).
#
# Workflow (see infra/aws/README.md):
#   1. cp infra/env/backend/.env.staging.example infra/env/backend/.env.staging
#   2. fill in REAL values below
#   3. pnpm dlx @dotenvx/dotenvx encrypt -f infra/env/backend/.env.staging
#      → rewrites the file as `encrypted:…` ciphertext (safe to commit) and writes
#        the private key to infra/env/backend/.env.keys (GITIGNORED).
#   4. push the private key to SSM:
#      aws ssm put-parameter --profile sekar --region ap-southeast-3 \
#        --name /swat/staging/BE_DOTENV_PRIVATE_KEY --type SecureString \
#        --value "$(grep DOTENV_PRIVATE_KEY_STAGING infra/env/backend/.env.keys | cut -d= -f2- | tr -d '\"')"
#   5. commit the encrypted infra/env/backend/.env.staging.
#
# NODE_ENV / BE_PORT / REDIS_URL are set by compose.staging.yml and override anything here.

# --- Database (shared AWS RDS instance `dlhsby`, SWAT database `swat_staging`, SSL) --
DATABASE_URL=postgresql://swat:CHANGE_ME@dlhsby.cvuoeguwo5dg.ap-southeast-3.rds.amazonaws.com:5432/swat_staging?schema=public&sslmode=require

# --- Auth / sessions --------------------------------------------------------
SESSION_SECRET=CHANGE_ME_min_16_chars_random
JWT_SECRET=CHANGE_ME_min_16_chars_random

# Cross-subdomain cookie: web on swat.wahyutrip.com, API on api.swat.wahyutrip.com.
SESSION_COOKIE_DOMAIN=.swat.wahyutrip.com
SESSION_COOKIE_SAMESITE=lax

# --- CORS (pin to the web origin; credentials are always allowed) -----------
CORS_ORIGIN=https://swat.wahyutrip.com

# --- Object storage: real AWS S3 via the EC2 instance role (no static keys) --
S3_USE_INSTANCE_ROLE=true
S3_FORCE_PATH_STYLE=false
S3_REGION=ap-southeast-3
S3_BUCKET=swat-photos-staging
S3_REPORTS_BUCKET=swat-reports-staging

# --- Maps: server-side Google Directions (Phase 7.8) ------------------------
# Snaps a route's auto-default corridor to roads. NOT the web browser key (that's
# referrer-restricted and lives in infra/env/web) — use a SEPARATE key restricted
# by the staging server's egress IP, with the Directions API enabled. Optional:
# leave empty → a route's default corridor is a straight line between its sites.
GOOGLE_MAPS_SERVER_KEY=

# --- GPS tracking — GPS.id integration (Phase 7) ----------------------------
# Inbound webhook (PRIMARY push path). REQUIRED in production (boot fails without
# it); GPS.id POSTs to /integrations/gps/webhook/<token>. Generate a long random
# secret and register it with GPS.id (see docs/GPSID-REGISTRATION.md).
GPS_WEBHOOK_TOKEN=CHANGE_ME_min_16_chars_random
# Optional CSV IP allowlist for the webhook (empty = allow any source IP).
GPS_WEBHOOK_ALLOWED_IPS=
# Per-source ingest rate limit (requests/min). Default 600.
GPS_INGEST_RATE_LIMIT_PER_MIN=600
# A device with no ping within this many minutes is marked offline. Default 10.
GPS_DEVICE_OFFLINE_MINUTES=10

# GPS.id pull API (SECONDARY — nightly backfill + mileage reconcile). All three
# REQUIRED together to enable the nightly job; leave empty to disable it (the job
# no-ops, never an unauthenticated call). Credentials are operator-provided.
GPSID_BASE_URL=
GPSID_USERNAME=
GPSID_PASSWORD=
